</svg><style data-file-tree-scrollbar-gutter-measured="">:host { --trees-scrollbar-gutter-measured: 15px; }</style><style data-file-tree-unsafe-css="">@layer base, unsafe;
@layer unsafe {
  
  [data-item-focused='true']:not(:focus-visible)::before {
    outline: none !important;
  }
  @container measure (height < 1.5lh) {
    [data-truncate-marker] {
      opacity: 0 !important;
