details.houston-debug {
  interpolate-size: allow-keywords;
}
details.houston-debug::details-content {
  height: 0;
  overflow: clip;
  transition: height 0.2s ease-out, content-visibility 0.2s allow-discrete;
}
details.houston-debug[open]::details-content {
  height: auto;
}
.houston-debug-toggle {
  display: flex;
  width: 100%;
  align-items: center;
  justify-content: space-between;
  list-style: none;
  cursor: pointer;
  transition: opacity 0.15s ease;
}
.houston-debug-toggle::-webkit-details-marker {
  display: none;
}
.houston-debug-toggle:hover {
  opacity: 0.65;
}
.houston-chevron {
  transition: transform 0.2s ease-out;
}
details.houston-debug[open] .houston-chevron {
  transform: rotate(180deg);
}
